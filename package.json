{
  "name": "termux-runtime-panel",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Termux Runtime Control Panel - Manage sessions, terminals, and files from web browser",
  "author": "TRCP",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"vite\"",
    "dev:frontend": "vite",
    "dev:server": "tsx server/index.ts",
    "server:dev": "nodemon --exec tsx server/index.ts --watch server",
    "build": "tsc -b && vite build",
    "build:server": "tsc -p server/tsconfig.json",
    "start": "node server/dist/index.js",
    "lint": "eslint .",
    "preview": "vite preview",
    "postinstall": "echo 'TRCP installed successfully!'"
  },
